    ],
    "en": [
      "Fixed garbled Chinese update notes and restored mainland-friendly download routing.",
      "Fixed installer requests being misclassified as automated Cloudflare traffic.",
      "Fixed invalid macOS quarantine metadata, unopenable in-app updates, and unreliable old-app termination."
    ]
  },
